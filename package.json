{
  "name": "quasar-telegram-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--require=./scripts/crypto-hash-polyfill.cjs quasar dev",
    "dev:e2e": "NODE_OPTIONS=--require=./scripts/crypto-hash-polyfill.cjs quasar dev --port 4100 --hostname 127.0.0.1",
    "build": "NODE_OPTIONS=--require=./scripts/crypto-hash-polyfill.cjs quasar build",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:local": "node ./scripts/run-e2e-local.cjs"
  },
  "dependencies": {
    "@nostr-dev-kit/ndk": "^3.0.0",
    "@quasar/extras": "^1.17.0",
    "pinia": "^2.1.7",
    "quasar": "^2.17.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@quasar/app-vite": "2.1.0",
    "@types/node": "^20.17.0",
    "typescript": "~5.7.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=8.0.0",
    "yarn": ">=1.21.1"
  }
}
